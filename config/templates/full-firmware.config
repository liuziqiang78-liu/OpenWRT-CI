# ═══════════════════════════════════════════════════════════════
#  固件增强插件模板 v1
#  在 base-firmware.config 基础上增加常用功能
#  使用方式: 在 base-firmware.config 之后叠加此文件
#
#  分类:
#    E1 - 网络增强
#    E2 - 系统增强
#    E3 - 存储增强
#    E4 - 安全增强
#    E5 - 监控增强
# ═══════════════════════════════════════════════════════════════

# ═══════════════════════════════════════
#  E1: 网络增强
# ═══════════════════════════════════════

# ── DDNS 动态域名 ──
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_ddns-scripts=y
CONFIG_PACKAGE_ddns-scripts-cloudflare=y
CONFIG_PACKAGE_ddns-scripts-dnspod=y

# ── UPnP 端口映射 ──
CONFIG_PACKAGE_luci-app-upnp=y

# ── 网络诊断 ──
CONFIG_PACKAGE_luci-app-traceroute=y
CONFIG_PACKAGE_traceroute=y
CONFIG_PACKAGE_mtr=y
CONFIG_PACKAGE_tcping=y

# ── NTP 时间同步 ──
CONFIG_PACKAGE_ntpclient=y

# ═══════════════════════════════════════
#  E2: 系统增强
# ═══════════════════════════════════════

# ── Web 终端 ──
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_ttyd=y

# ── 定时任务 ──
CONFIG_PACKAGE_luci-app-cron=y

# ── 系统日志 ──
CONFIG_PACKAGE_luci-app-syslog=y
CONFIG_PACKAGE_syslog-ng=y

# ── 在线升级 ──
CONFIG_PACKAGE_luci-app-attendedsysupgrade=y

# ── SSH 服务 ──
CONFIG_PACKAGE_luci-app-sshd=y

# ═══════════════════════════════════════
#  E3: 存储增强
# ═══════════════════════════════════════

# ── 文件共享 ──
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_samba4-server=y
CONFIG_PACKAGE_samba4-libs=y

# ── FTP 服务 ──
CONFIG_PACKAGE_luci-app-vsftpd=y
CONFIG_PACKAGE_vsftpd-alt=y

# ── 网络文件系统 ──
CONFIG_PACKAGE_kmod-fs-nfs=y
CONFIG_PACKAGE_kmod-fs-nfs-common=y
CONFIG_PACKAGE_nfs-utils=y

# ═══════════════════════════════════════
#  E4: 安全增强
# ═══════════════════════════════════════

# ── 访问控制 ──
CONFIG_PACKAGE_luci-app-accesscontrol=y

# ── ARP 绑定 ──
CONFIG_PACKAGE_luci-app-arpbind=y

# ═══════════════════════════════════════
#  E5: 监控增强
# ═══════════════════════════════════════

# ── 实时监控 ──
CONFIG_PACKAGE_luci-app-nlbwmon=y
CONFIG_PACKAGE_nlbwmon=y

# ── 带宽测试 ──
CONFIG_PACKAGE_speedtest-cli=y
CONFIG_PACKAGE_iperf3=y
