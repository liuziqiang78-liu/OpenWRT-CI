# ═══════════════════════════════════════════════════════════════
#  固件基础插件模板 v1
#  所有设备共享的最小可用固件配置
#
#  分类:
#    L1 - 系统核心 (必须)
#    L2 - LuCI 界面 (必须)
#    L3 - 网络基础 (必须)
#    L4 - 存储/文件系统 (推荐)
#    L5 - USB 支持 (推荐)
#    L6 - LED/按键 (推荐)
#    L7 - 中文支持 (推荐)
#    L8 - 性能优化 (可选)
#
#  标记:
#    [必须] - 固件无法正常使用
#    [推荐] - 大多数场景需要
#    [可选] - 按需启用
# ═══════════════════════════════════════════════════════════════

# ═══════════════════════════════════════
#  L1: 系统核心 [必须]
# ═══════════════════════════════════════

# ── 多设备支持 ──
CONFIG_TARGET_MULTI_PROFILE=y

# ── 基础系统 ──
CONFIG_PACKAGE_base-files=y
CONFIG_PACKAGE_busybox=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dropbear=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_f2fs-tools=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_losetup=y
CONFIG_PACKAGE_opkg=y
CONFIG_PACKAGE_procd=y
CONFIG_PACKAGE_ubox=y
CONFIG_PACKAGE_ubus=y
CONFIG_PACKAGE_uci=y
CONFIG_PACKAGE_urandom-seed=y
CONFIG_PACKAGE_urngd=y

# ── 网络核心 ──
CONFIG_PACKAGE_netifd=y
CONFIG_PACKAGE_jsonfilter=y
CONFIG_PACKAGE_usign=y

# ═══════════════════════════════════════
#  L2: LuCI 界面 [必须]
# ═══════════════════════════════════════

# ── LuCI 核心 ──
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-lib-ip=y
CONFIG_PACKAGE_luci-lib-jsonc=y
CONFIG_PACKAGE_luci-lib-nixio=y

# ── LuCI 主题 ──
CONFIG_PACKAGE_luci-theme-bootstrap=y

# ── LuCI 核心应用 ──
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-opkg=y
CONFIG_PACKAGE_luci-app-system=y
CONFIG_PACKAGE_luci-app-network=y
CONFIG_PACKAGE_luci-app-status=y

# ═══════════════════════════════════════
#  L3: 网络基础 [必须]
# ═══════════════════════════════════════

# ── 防火墙 (由防火墙模板覆盖) ──
# CONFIG_PACKAGE_firewall=y              ← firewall-iptables.config
# CONFIG_PACKAGE_iptables=y              ← firewall-iptables.config

# ── DHCP/DNS ──
CONFIG_PACKAGE_dnsmasq-full=y

# ── 网络工具 ──
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_iptables-mod-ipopt=y
CONFIG_PACKAGE_tcpdump-mini=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y

# ── PPP ──
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y
CONFIG_PACKAGE_ppp-mod-pppol2tp=y
CONFIG_PACKAGE_ppp-mod-pptp=y

# ═══════════════════════════════════════
#  L4: 存储/文件系统 [推荐]
# ═══════════════════════════════════════

CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_f2fs-tools=y
CONFIG_PACKAGE_f2fsck=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-f2fs=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-extras=y
CONFIG_PACKAGE_kmod-scsi-core=y

# ═══════════════════════════════════════
#  L5: USB 支持 [推荐]
# ═══════════════════════════════════════

CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb-dwc3=y
CONFIG_PACKAGE_kmod-usb-dwc3-qcom=y
CONFIG_PACKAGE_usbutils=y

# ═══════════════════════════════════════
#  L6: LED/按键 [推荐]
# ═══════════════════════════════════════

CONFIG_PACKAGE_kmod-leds-gpio=y
CONFIG_PACKAGE_kmod-ledtrig-default-on=y
CONFIG_PACKAGE_kmod-ledtrig-heartbeat=y
CONFIG_PACKAGE_kmod-ledtrig-netdev=y
CONFIG_PACKAGE_kmod-ledtrig-timer=y
CONFIG_PACKAGE_kmod-gpio-button-hotplug=y
CONFIG_PACKAGE_luci-app-ledtrig-rssi=y
CONFIG_PACKAGE_luci-app-ledtrig-switch=y
CONFIG_PACKAGE_luci-app-ledtrig-usbport=y

# ═══════════════════════════════════════
#  L7: 中文支持 [推荐]
# ═══════════════════════════════════════

CONFIG_LUCI_LANG_zh_Hans=y

# ═══════════════════════════════════════
#  L8: 性能优化 [可选]
# ═══════════════════════════════════════

# ── SQM 流量整形 ──
CONFIG_PACKAGE_luci-app-sqm=y

# ── 磁盘管理 ──
CONFIG_PACKAGE_luci-app-diskman=y

# ── 自动挂载 ──
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_automount=y

# ── 时钟频率 ──
CONFIG_PACKAGE_cpufreq=y

# ═══════════════════════════════════════
#  L9: WiFi 基础 (按平台由驱动包提供)
# ═══════════════════════════════════════

# ── WiFi 工具 ──
CONFIG_PACKAGE_wpad-openssl=y
CONFIG_PACKAGE_wireless-tools=y
CONFIG_PACKAGE_wpa-cli=y
CONFIG_PACKAGE_hostapd-common=y

# ═══════════════════════════════════════
#  L10: 自动化/升级 [可选]
# ═══════════════════════════════════════

CONFIG_PACKAGE_luci-app-attendedsysupgrade=y
CONFIG_PACKAGE_attendedsysupgrade-common=y

# ═══════════════════════════════════════
#  平台特定包 (由 _platform.yml 注入)
# ═══════════════════════════════════════

# 以下由 generate-config.sh 根据平台自动添加:
# - ath11k / mt76 WiFi 驱动
# - NSS 硬件加速 (qualcomm)
# - 平台默认包
