#!/sbin/sh

#################
# Module Installer
# 兼容 APatch / KernelSU / Magisk
#################

ZIPFILE=$3
OUTFD=$2
MODDIR=$(dirname "$ZIPFILE")

# 检测 root 方案并加载工具函数
if [ -f /data/adb/apatch/util_functions.sh ]; then
    . /data/adb/apatch/util_functions.sh
elif [ -f /data/adb/ksu/bin/ksu_functions.sh ]; then
    . /data/adb/ksu/bin/ksu_functions.sh
elif [ -f /data/adb/magisk/util_functions.sh ]; then
    . /data/adb/magisk/util_functions.sh
else
    # 无 util_functions.sh 时的兼容实现
    ui_print() {
        echo "$1"
    }
    
    abort() {
        ui_print "错误: $1"
        exit 1
    }
    
    install_module() {
        ui_print "- 解压模块文件..."
        
        # 解压到临时目录
        TMPDIR=/data/local/tmp/mimo_module
        rm -rf "$TMPDIR"
        mkdir -p "$TMPDIR"
        
        cd "$TMPDIR"
        unzip -o "$ZIPFILE" -d "$TMPDIR" > /dev/null 2>&1
        
        # 执行 customize.sh
        if [ -f "$TMPDIR/customize.sh" ]; then
            sh "$TMPDIR/customize.sh"
        fi
        
        # 清理
        rm -rf "$TMPDIR"
    }
fi

# 如果有 install_module 函数则调用，否则手动执行
if command -v install_module > /dev/null 2>&1; then
    install_module
else
    # 手动安装
    TMPDIR=/data/local/tmp/mimo_module
    rm -rf "$TMPDIR"
    mkdir -p "$TMPDIR"
    
    cd "$TMPDIR"
    unzip -o "$ZIPFILE" -d "$TMPDIR" > /dev/null 2>&1
    
    if [ -f "$TMPDIR/customize.sh" ]; then
        sh "$TMPDIR/customize.sh"
    fi
    
    rm -rf "$TMPDIR"
fi

exit 0
